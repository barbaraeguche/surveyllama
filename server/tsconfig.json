{
	"compilerOptions": {
		"target": "ES2020",
		"module": "commonjs",
		"rootDir": "./src",
		"outDir": "./dist",
		"allowSyntheticDefaultImports": true,
		// Other Outputs
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,
		// Recommended Options
		"strict": true,
		"jsx": "react-jsx",
		// "verbatimModuleSyntax": true,
		"isolatedModules": true,
		"noUncheckedSideEffectImports": true,
		"moduleDetection": "force",
		"skipLibCheck": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipDefaultLibCheck": true
	},
	"include": [
		"**/*.ts"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}